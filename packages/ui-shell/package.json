{
  "name": "@eappflow/ui-shell",
  "version": "0.2.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./services": {
      "types": "./dist/services/interfaces.d.ts",
      "import": "./dist/services/interfaces.js",
      "require": "./dist/services/interfaces.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build && vue-tsc --declaration --emitDeclarationOnly",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "mitt": "^3.0.0",
    "primevue": "^4.0.0",
    "primeicons": "^7.0.0",
    "@eappflow/ui-shell-core": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.5.0",
    "vue-router": "^4.5.0",
    "pinia": "^2.2.0",
    "primevue": "^4.0.0",
    "primeicons": "^7.0.0",
    "@eappflow/ui-shell-components": "workspace:*",
    "@eappflow/ui-shell-core": "workspace:*"
  },
  "devDependencies": {
    "@eappflow/ui-shell-components": "workspace:*",
    "@vitejs/plugin-vue": "^5.2.0",
    "pinia": "^2.2.0",
    "typescript": "~5.7.0",
    "vite": "^6.1.0",
    "vitest": "^3.0.0",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0",
    "vue-tsc": "^2.2.0"
  },
  "publishConfig": {
    "access": "public"
  }
}