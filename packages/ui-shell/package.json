{
  "name": "@eappflow/ui-shell",
  "version": "0.2.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./services": {
      "types": "./dist/services/interfaces.d.ts",
      "import": "./dist/services/interfaces.js",
      "require": "./dist/services/interfaces.cjs"
    },
    "./style": {
      "style": "./dist/ui-shell.css",
      "import": "./dist/ui-shell.css",
      "require": "./dist/ui-shell.css"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && vue-tsc --declaration --emitDeclarationOnly",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@azure/msal-browser": "^5.16.0",
    "@vueuse/core": "^14.3.0",
    "mitt": "^3.0.1",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5"
  },
  "peerDependencies": {
    "@eappflow/ui-shell-components": "workspace:*",
    "pinia": "^2.2.0",
    "primeicons": "^7.0.0",
    "primevue": "^4.0.0",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@eappflow/ui-shell-components": "workspace:*",
    "@tailwindcss/vite": "^4.3.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0",
    "vue-tsc": "^3.3.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
