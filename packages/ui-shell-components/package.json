    "test": "vitest run"
  },
  "peerDependencies": {
    "pinia": "^3.0.4 || ^4.0.2",
    "primevue": "^4.0.0",
    "vue": "^3.5.0 || ^4.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "pinia": "^3.0.4",
    "primevue": "^4.5.5",
    "tailwindcss-primeui": "^0.6.1",
    "typescript": "~6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "vue": "^3.5.38",
    "vue-tsc": "^3.3.5"
  },
  "publishConfig": {
    "access": "public"
  }
