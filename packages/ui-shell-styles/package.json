{
  "name": "@eappflow/ui-shell-styles",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tailwind": {
      "types": "./tailwind.config.d.ts",
      "import": "./tailwind.config.ts",
      "require": "./tailwind.config.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.0",
    "typescript": "~5.7.0",
    "vite": "^6.1.0",
    "vitest": "^3.0.0",
    "vue-tsc": "^2.2.0"
  },
  "publishConfig": {
    "access": "public"
  }
}